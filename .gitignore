# Python
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# 用户配置（含本地路径，由 bootstrap.py 自动生成）
.cursor/mcp.json

# 视频 / 预处理产物 / 输出（由 portable-gpu-worker/.gitignore 负责，此处冗余保底）
portable-gpu-worker/videos/**
portable-gpu-worker/_env/**
portable-gpu-worker/output/**
!portable-gpu-worker/videos/.gitkeep
!portable-gpu-worker/_env/.gitkeep
!portable-gpu-worker/output/.gitkeep

# 运行时临时文件
scripts/_gui_result.json
anki_result.txt

# 生成产物
*.apkg

# 大文件 / 打包产物
portable-gpu-worker.zip

# IDE / 编辑器
.idea/
*.swp
*.swo

# 跟踪工作流必需配置（其余本地文件继续忽略）
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/mcp.json

.claude/*
!.claude/commands/
!.claude/commands/*.md

# 系统文件
.DS_Store
Thumbs.db
