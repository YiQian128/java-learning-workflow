# ──────────────────────────────────────────────────────
# portable-gpu-worker 密钥配置模板
# 用法：复制此文件为 .env，填入真实密钥，.env 文件已被 git 忽略。
# ──────────────────────────────────────────────────────

# 阿里云 DashScope API Key（用于 Paraformer 转写）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 阿里云 OSS 凭证（用于上传音频文件供 Paraformer 访问）
# 获取地址：https://ram.console.aliyun.com/（建议使用子账户，授权 oss:PutObject/GetObject/DeleteObject）
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
ALIYUN_OSS_BUCKET=your_bucket_name_here

# ── 其他提供商（按需填写，未使用的保持注释即可）──────────
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# SILICONFLOW_API_KEY=sk-...
# ASSEMBLYAI_API_KEY=...
# DEEPGRAM_API_KEY=...
